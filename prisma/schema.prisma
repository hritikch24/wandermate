generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  avatar        String?
  bio           String?
  age           Int?
  phone         String?
  languages     String    @default("[]")
  interests     String    @default("[]")
  travelStyle   String?
  verified      Boolean   @default(false)
  rating        Float     @default(0)
  tripsCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trips         Trip[]
  guideProfile  Guide?
  sentMessages  Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  reviewsGiven  Review[]  @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewTarget")
  bookings      Booking[]

  @@index([email])
}

model Trip {
  id            String   @id @default(cuid())
  userId        String
  destination   String
  title         String
  description   String?
  startDate     DateTime
  endDate       DateTime
  sponsorType   String
  budget        String?
  groupSize     String   @default("2-4")
  accommodation String   @default("flexible")
  interests     String   @default("[]")
  status        String   @default("open")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([destination])
  @@index([sponsorType])
  @@index([status])
}

model Guide {
  id            String   @id @default(cuid())
  userId        String   @unique
  speciality    String
  city          String
  pricePerDay   Int
  expertise     String   @default("[]")
  availability  String   @default("Available now")
  localSince    String
  toursCompleted Int     @default(0)
  verified      Boolean  @default(false)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings      Booking[]

  @@index([city])
  @@index([active])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Review {
  id         String   @id @default(cuid())
  authorId   String
  targetId   String
  rating     Int
  comment    String
  tripCity   String?
  createdAt  DateTime @default(now())

  author     User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target     User     @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([authorId, targetId])
  @@index([targetId])
}

model Booking {
  id        String   @id @default(cuid())
  userId    String
  guideId   String
  startDate DateTime
  endDate   DateTime
  status    String   @default("pending")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  guide     Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([guideId])
  @@index([status])
}
