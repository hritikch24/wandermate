generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  avatar        String?
  bio           String?
  age           Int?
  phone         String?
  phoneVerified Boolean   @default(false)
  aadhaarVerified Boolean @default(false)
  languages     String    @default("[]")
  interests     String    @default("[]")
  travelStyle   String?
  instagram     String?
  facebook      String?
  twitter       String?
  linkedin      String?
  socialLinks   String    @default("{}") // JSON for any extra links
  verified      Boolean   @default(false)
  rating        Float     @default(0)
  tripsCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trips         Trip[]
  tripRequests  TripRequest[] @relation("TripRequestsSent")
  guideProfile  Guide?
  sentMessages  Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  reviewsGiven  Review[]  @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewTarget")
  bookings      Booking[]
  tripMembers   TripMember[]
  groupMessages GroupMessage[]
  reportsMade   Report[]  @relation("ReportsMade")
  reportsReceived Report[] @relation("ReportsReceived")
  blocksMade    Block[]   @relation("BlocksMade")
  blocksReceived Block[]  @relation("BlocksReceived")

  @@index([email])
}

model Trip {
  id            String   @id @default(cuid())
  userId        String
  destination   String
  title         String
  description   String?
  startDate     DateTime
  endDate       DateTime
  sponsorType   String
  budget        String?
  groupSize     String   @default("2-4")
  accommodation String   @default("flexible")
  interests     String   @default("[]")
  status        String   @default("open")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests      TripRequest[]
  group         TripGroup?

  @@index([destination])
  @@index([sponsorType])
  @@index([status])
}

model Guide {
  id            String   @id @default(cuid())
  userId        String   @unique
  speciality    String
  city          String
  pricePerDay   Int
  expertise     String   @default("[]")
  availability  String   @default("Available now")
  localSince    String
  toursCompleted Int     @default(0)
  verified      Boolean  @default(false)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings      Booking[]

  @@index([city])
  @@index([active])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Review {
  id         String   @id @default(cuid())
  authorId   String
  targetId   String
  rating     Int
  comment    String
  tripCity   String?
  createdAt  DateTime @default(now())

  author     User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target     User     @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([authorId, targetId])
  @@index([targetId])
}

model TripRequest {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  message   String?
  status    String   @default("pending") // pending | accepted | rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation("TripRequestsSent", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId])
  @@index([userId])
  @@index([status])
}

model Booking {
  id        String   @id @default(cuid())
  userId    String
  guideId   String
  startDate DateTime
  endDate   DateTime
  status    String   @default("pending")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  guide     Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([guideId])
  @@index([status])
}

model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  purpose   String   @default("register") // register | aadhaar
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, purpose])
}

model PageView {
  id          String   @id @default(cuid())
  path        String
  referrer    String?
  utmSource   String?  @map("utm_source")
  utmMedium   String?  @map("utm_medium")
  utmCampaign String?  @map("utm_campaign")
  device      String?
  browser     String?
  country     String?
  ip          String?
  sessionId   String   @map("session_id")
  subdomain   String?
  createdAt   DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([sessionId])
  @@index([subdomain])
  @@map("page_views")
}

model ButtonClick {
  id          String   @id @default(cuid())
  action      String   // connect_request, book_guide, chat_start, signup, profile_view, trip_create
  page        String
  targetId    String?
  referrer    String?
  utmSource   String?  @map("utm_source")
  utmMedium   String?  @map("utm_medium")
  utmCampaign String?  @map("utm_campaign")
  device      String?
  browser     String?
  country     String?
  ip          String?
  sessionId   String   @map("session_id")
  subdomain   String?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@index([sessionId])
  @@map("button_clicks")
}

model TripGroup {
  id        String   @id @default(cuid())
  tripId    String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  members   TripMember[]
  messages  GroupMessage[]

  @@index([tripId])
  @@map("trip_groups")
}

model TripMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("member") // owner | member
  joinedAt  DateTime @default(now())

  group     TripGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("trip_members")
}

model GroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  group     TripGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([senderId])
  @@index([createdAt])
  @@map("group_messages")
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reportedId String
  reason     String   // harassment | fake_profile | scam | inappropriate | safety_concern | other
  details    String?
  status     String   @default("pending") // pending | reviewed | resolved | dismissed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  reporter   User     @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reported   User     @relation("ReportsReceived", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([reportedId])
  @@index([status])
  @@map("reports")
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker   User     @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocks")
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?
  category    String   // hidden-gems, itinerary, guide, packing, festival, food, budget
  state       String?
  city        String?
  tags        String   @default("[]") // JSON array
  author      String   @default("Luventra Team")
  published   Boolean  @default(true)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([state])
  @@index([published])
  @@map("blog_posts")
}
