# Luventra Configuration

# Database — get from neon.tech (free PostgreSQL)
# Pooled connection (for Prisma Client queries via serverless)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
# Direct connection (for Prisma Migrate / db push)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth
NEXTAUTH_SECRET="change-this-to-a-random-string-in-production"
NEXTAUTH_URL="http://localhost:3000"
